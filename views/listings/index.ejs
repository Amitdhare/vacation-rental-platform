<% layout("/layouts/boilerPlate")%>

    <body>
        <h1>AllListings</h1>
        
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
            <% for(let listing of allListings){%>
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card col listing-card" style="width: 20rem ; ">
                        <img src="<%=listing.image.url%>" class="card-img-top" alt="listings_image "
                            style="height: 20rem;" />
                            <div class="card-img-overlay">absd</div>
                        <div class="card-body">
                            <div class="card-text">
                                <b>
                                    <%= listing.title %>
                                </b> <br>
                                &#x20B9;<%= listing.price.toLocaleString("en-IN") %>
                                    </p>


                            </div>

                        </div>
                    </div>
                </a>

                <% }%>
        </div>


    </body>